  const accent=ACCENT[detailKey];
  const keys=Object.keys(ARCHETYPES);
  const idx=keys.indexOf(detailKey);
  const prev=keys[(idx-1+keys.length)%keys.length];
  const next=keys[(idx+1)%keys.length];

  const balanceHTML=arch.balance.map(b=>{
    const a=ARCHETYPES[b.key];
    return `<div class="arch-rec"><div class="rec-symbol-wrap">${a.symbol}</div><div class="rec-body"><div class="rec-name">${a.name}</div><div class="rec-text">${b.why}</div></div></div>`;
  }).join('');

  app.innerHTML=`
  ${navBar('biblioteca')}
  <div class="arch-detail">

    <!-- Back + navigation -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
      <button class="btn-back" onclick="goBiblioteca()">← Todos los arquetipos</button>
      <div style="display:flex;gap:6px;">
        <button class="btn-back" onclick="goDetail('${prev}')" title="${ARCHETYPES[prev].name}">← ${ARCHETYPES[prev].symbol}</button>
        <button class="btn-back" onclick="goDetail('${next}')" title="${ARCHETYPES[next].name}">${ARCHETYPES[next].symbol} →</button>
      </div>
    </div>

    <!-- Header -->
    <div class="detail-header">
      <div style="position:absolute;top:0;left:0;right:0;height:5px;background:${accent};border-radius:24px 24px 0 0;"></div>
      <div class="hero-node" style="width:10px;height:10px;background:var(--sun);top:16px;left:20px;opacity:0.6;"></div>
      <div class="hero-node" style="width:7px;height:7px;background:${accent};top:22px;right:28px;"></div>
      <div style="display:flex;justify-content:center;gap:8px;margin-bottom:10px;opacity:0.3;">
        <span style="color:${accent};">${starSVG}</span><span style="color:var(--sun);">${starSVG}</span>
      </div>
      <span class="arch-symbol-big">${arch.symbol}</span>
      <div class="arch-name">${arch.name}</div>
      <div class="arch-latin">${arch.latin}</div>
      <div class="arch-traits">${arch.traits.map(t=>`<span class="trait-pill">${t}</span>`).join('')}</div>
    </div>

    <!-- Core -->
    <div class="rsection"><div class="rsection-accent sun"></div>
      <div class="rsection-label">${nd('sun')} Esencia</div>
      <p class="rsection-text">${arch.core}</p>
    </div>

    <!-- Behaviors -->
    <div class="rsection"><div class="rsection-accent fire"></div>
      <div class="rsection-label">${nd('fire')} Cómo se reconoce</div>
      <p class="rsection-text">Patrones de comportamiento característicos:</p>
      <ul class="behavior-list">${arch.behaviors.map(b=>`<li><span class="bnode"></span><span>${b}</span></li>`).join('')}</ul>
    </div>

    <!-- Shadow -->
    <div class="rsection"><div class="rsection-accent blush"></div>
      <div class="rsection-label">${nd('blush')} La Sombra</div>
      <p class="rsection-text">${arch.shadow}</p>
      <div class="shadow-inner">
        <div class="shadow-label">${nd('blush')} Manifestaciones de sombra</div>
        <ul class="behavior-list">${arch.shadow_behaviors.map(b=>`<li class="shadow-li"><span class="bnode"></span><span>${b}</span></li>`).join('')}</ul>
      </div>
    </div>

    <!-- Balance -->
    <div class="rsection"><div class="rsection-accent ink"></div>
      <div class="rsection-label">${nd('ink')} Arquetipos complementarios</div>
      <p class="rsection-text" style="margin-bottom:4px;">Para equilibrar este arquetipo y trabajar su sombra:</p>
      <div class="arch-recs">${balanceHTML}</div>
    </div>

    <!-- Ejemplos -->
    <div class="rsection"><div class="rsection-accent" style="background:${accent};"></div>
      <div class="rsection-label">${nd('sun')} En la cultura</div>
      <p class="rsection-text">${arch.ejemplos}</p>
    </div>

    <!-- Pregunta -->
    <div class="rsection" style="border:1.5px dashed var(--ink-faint);background:var(--cream);">
      <div class="rsection-accent" style="background:${accent};"></div>
      <div class="rsection-label">${nd('sun')} Pregunta para integrar</div>
      <p class="rsection-text" style="font-style:italic;font-family:'Playfair Display',serif;font-size:17px;line-height:1.6;">"${arch.pregunta}"</p>
    </div>

    <!-- CTA -->
    <div style="margin-top:8px;display:flex;gap:10px;flex-wrap:wrap;">
      <button class="btn-primary" style="flex:1;justify-content:center;" onclick="startQuiz()"><span class="dot"></span>Hacer el test<span class="dot" style="background:var(--fire);"></span></button>
      <button class="btn-ghost" style="flex:1;" onclick="goBiblioteca()">← Volver</button>
    </div>
  </div>`;
}

render();
</script>
</body>
</html>
