// ── State ──
let screen = 'intro'; // intro | quiz | result | biblioteca | arch-detail
let prevScreen = 'intro';
let q = 0;
let answers = new Array(QUESTIONS.length).fill(null); // stores chosen index per question
let scores = {heroe:0,mago:0,sabio:0,explorador:0,amante:0,cuidador:0,creador:0,rebelde:0};
let busy = false;
let detailKey = null;
let showExitModal = false;

function calcScores(){
  const s = {heroe:0,mago:0,sabio:0,explorador:0,amante:0,cuidador:0,creador:0,rebelde:0};
  answers.forEach((idx, qi) => {
    if(idx === null) return;
    const chosen = QUESTIONS[qi].options[idx];
    for(const [k,v] of Object.entries(chosen.a)) s[k] += v;
  });
  return s;
}

function allAnswered(){ return answers.every(a => a !== null); }

