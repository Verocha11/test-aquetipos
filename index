function navBar(active){
  const inQuiz = screen==='quiz';
  if(inQuiz) return ''; // no nav during quiz
  return `<div class="nav">
    <div class="nav-logo" onclick="goHome()"><span>◯</span> Arquetipos</div>
    <div class="nav-tabs">
      <button class="nav-tab ${active==='test'?'active':''}" onclick="goHome()">Test</button>
      <button class="nav-tab ${active==='biblioteca'?'active':''}" onclick="goBiblioteca()">Explorar</button>
    </div>
  </div>`;
}

function go(s){ prevScreen=screen; screen=s; showExitModal=false; render(); }
function goHome(){ q=0; answers=new Array(QUESTIONS.length).fill(null); scores={}; busy=false; showExitModal=false; go('intro'); }
function goBiblioteca(){ go('biblioteca'); }
function goDetail(key){ detailKey=key; go('arch-detail'); }
function startQuiz(){ q=0; answers=new Array(QUESTIONS.length).fill(null); busy=false; go('quiz'); }
function confirmExit(){ showExitModal=true; render(); }
function cancelExit(){ showExitModal=false; render(); }
function jumpToQ(idx){ q=idx; render(); }
function goNext(){
  // find next unanswered after current, or just advance
  for(let i=q+1;i<QUESTIONS.length;i++){ if(answers[i]===null){ q=i; render(); return; } }
  // if all answered, show result
  if(allAnswered()){ scores=calcScores(); go('result'); return; }
  // otherwise just go to next
  if(q < QUESTIONS.length-1){ q++; render(); }
}

// ── Render ──
function render(){
  const app=document.getElementById('app');
  if(screen==='intro') renderIntro(app);
  else if(screen==='quiz') renderQ(app);
  else if(screen==='result') renderResult(app);
  else if(screen==='biblioteca') renderBiblioteca(app);
  else if(screen==='arch-detail') renderDetail(app);
  window.scrollTo({top:0,behavior:'smooth'});
}

