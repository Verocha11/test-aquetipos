<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Arquetipos — Test de Jung</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');

:root {
  --cream: #f5f0e8;
  --cream-dark: #ede6d6;
  --ink: #1a2744;
  --ink-light: #2d3d6b;
  --ink-faint: #c8cfe0;
  --sun: #f5c842;
  --sun-light: #f9df7a;
  --fire: #e8441a;
  --fire-light: #f07050;
  --blush: #e8c4d0;
  --blush-mid: #d4a0b8;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background-color: var(--cream);
  background-image:
    radial-gradient(circle at 15% 20%, rgba(245,200,66,0.08) 0%, transparent 40%),
    radial-gradient(circle at 85% 80%, rgba(232,68,26,0.06) 0%, transparent 40%);
  color: var(--ink);
  font-family: 'Nunito', sans-serif;
  min-height: 100vh;
  padding: 32px 20px 80px;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  position: relative;
  overflow-x: hidden;
}

body::before {
  content: '';
  position: fixed; inset: 0;
  pointer-events: none; z-index: 0;
  background-image:
    radial-gradient(1.5px 1.5px at 8% 12%, var(--ink-faint) 100%, transparent),
    radial-gradient(1.5px 1.5px at 92% 8%, var(--sun) 100%, transparent),
    radial-gradient(1px 1px at 20% 88%, var(--ink-faint) 100%, transparent),
    radial-gradient(1.5px 1.5px at 78% 90%, var(--fire-light) 100%, transparent),
    radial-gradient(1px 1px at 50% 5%, var(--ink-faint) 100%, transparent),
    radial-gradient(1.5px 1.5px at 5% 55%, var(--sun) 100%, transparent),
    radial-gradient(1px 1px at 95% 45%, var(--ink-faint) 100%, transparent);
}

.container { max-width: 640px; width: 100%; position: relative; z-index: 1; }

/* ── NAV BAR ── */
.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32px;
  gap: 8px;
}
.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 15px; font-weight: 700;
  color: var(--ink);
  display: flex; align-items: center; gap: 8px;
  cursor: pointer;
}
.nav-logo span { font-size: 18px; }
.nav-tabs {
  display: flex; gap: 4px;
  background: white;
  border: 1.5px solid var(--ink-faint);
  border-radius: 100px;
  padding: 4px;
}
.nav-tab {
  background: transparent;
  border: none;
  border-radius: 100px;
  padding: 7px 16px;
  font-family: 'Nunito', sans-serif;
  font-size: 11px; letter-spacing: 1.5px;
  font-weight: 700; text-transform: uppercase;
  color: var(--ink-light);
  cursor: pointer;
  transition: all 0.25s;
  white-space: nowrap;
}
.nav-tab.active {
  background: var(--ink);
  color: var(--cream);
}
.nav-tab:hover:not(.active) { background: var(--cream-dark); }

/* ── SHARED COMPONENTS ── */
.eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
  color: var(--ink-light); font-weight: 700;
  background: var(--cream-dark);
  border: 1.5px solid var(--ink-faint);
  padding: 6px 14px; border-radius: 20px;
}

.divider-svg { width: 100%; margin: 24px 0; display: block; }

.btn-primary {
  background: var(--ink); color: var(--cream);
  font-family: 'Nunito', sans-serif;
  font-size: 12px; letter-spacing: 3px; text-transform: uppercase; font-weight: 700;
  border: none; padding: 16px 48px; border-radius: 100px;
  cursor: pointer; transition: all 0.3s;
  display: inline-flex; align-items: center; gap: 10px;
}
.btn-primary:hover { background: var(--ink-light); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,39,68,0.2); }
.btn-primary .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--sun); flex-shrink: 0; }

.btn-ghost {
  background: transparent; border: 1.5px solid var(--ink-faint);
  color: #8090b8; font-family: 'Nunito', sans-serif;
  font-size: 11px; letter-spacing: 2px; text-transform: uppercase; font-weight: 700;
  padding: 12px 28px; border-radius: 100px; cursor: pointer; transition: all 0.3s;
}
.btn-ghost:hover { border-color: var(--ink); color: var(--ink); }

.btn-back {
  background: transparent; border: 1.5px solid var(--ink-faint);
  color: var(--ink-light); font-family: 'Nunito', sans-serif;
  font-size: 11px; letter-spacing: 1px; text-transform: uppercase; font-weight: 700;
  padding: 8px 16px; border-radius: 100px; cursor: pointer; transition: all 0.2s;
  display: inline-flex; align-items: center; gap: 6px;
}
.btn-back:hover { border-color: var(--ink); color: var(--ink); }

/* ── INTRO ── */
.intro { animation: fadeUp 0.7s ease both; text-align: center; }
.intro h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 8vw, 52px); font-weight: 700;
  color: var(--ink); line-height: 1.1; margin-bottom: 8px;
}
.intro-subtitle {
  font-size: 16px; line-height: 1.7; color: var(--ink-light);
  max-width: 460px; margin: 0 auto 32px; font-style: italic;
}

.constellation-wrap { margin: 0 auto 28px; width: 110px; height: 110px; }
.constellation-ring {
  width: 100%; height: 100%;
  border: 2px dashed var(--ink-faint); border-radius: 50%;
  position: relative; display: flex; align-items: center; justify-content: center;
  animation: spinSlow 30s linear infinite;
}
.node-orbit {
  position: absolute; width: 10px; height: 10px;
  border-radius: 50%; background: var(--fire); border: 2px solid white;
}
.node-orbit:nth-child(1) { top:-5px; left:50%; transform:translateX(-50%); background:var(--sun); }
.node-orbit:nth-child(2) { right:-5px; top:50%; transform:translateY(-50%); }
.node-orbit:nth-child(3) { bottom:-5px; left:50%; transform:translateX(-50%); background:var(--blush-mid); }
.node-orbit:nth-child(4) { left:-5px; top:50%; transform:translateY(-50%); background:var(--ink); }
.center-symbol {
  font-family: 'Playfair Display', serif; font-size: 28px; color: var(--ink);
  position: absolute; animation: spinSlow 30s linear infinite reverse;
}

.intro-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 10px; margin: 0 0 32px; text-align: left;
}
.intro-tile {
  background: white; border: 1.5px solid var(--ink-faint);
  border-radius: 12px; padding: 16px 18px; position: relative; overflow: hidden;
}
.intro-tile::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--sun);
}
.intro-tile:nth-child(2)::before { background: var(--fire); }
.intro-tile:nth-child(3)::before { background: var(--blush-mid); }
.intro-tile:nth-child(4)::before { background: var(--ink-light); }
.intro-tile-label {
  font-size: 9px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--ink-light); font-weight: 700; margin-bottom: 8px;
  display: flex; align-items: center; gap: 6px;
}
.intro-tile p { font-size: 13px; line-height: 1.6; color: #4a5580; }

/* ── PROGRESS ── */
.progress-area { margin-bottom: 28px; }
.progress-track { height: 4px; background: var(--ink-faint); border-radius: 4px; overflow: hidden; margin-bottom: 14px; }
.progress-fill {
  height: 100%; background: linear-gradient(90deg, var(--sun), var(--fire));
  border-radius: 4px; transition: width 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
}
.progress-fill::after {
  content: ''; position: absolute; right: -1px; top: -2px;
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--fire); border: 2px solid var(--cream);
}
/* Step dots */
.progress-dots { display: flex; gap: 6px; justify-content: center; flex-wrap: wrap; }
.pdot {
  width: 28px; height: 28px; border-radius: 50%;
  border: 1.5px solid var(--ink-faint);
  background: var(--cream); color: var(--ink-light);
  font-size: 9px; font-weight: 700; letter-spacing: 0;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all 0.2s; font-family: 'Nunito', sans-serif;
  flex-shrink: 0;
}
.pdot.answered { background: var(--ink-faint); border-color: var(--ink-light); color: var(--ink); }
.pdot.current { background: var(--ink); border-color: var(--ink); color: var(--cream); transform: scale(1.15); box-shadow: 0 0 0 3px rgba(26,39,68,0.15); }
.pdot.answered:hover:not(.current) { border-color: var(--fire); background: #fef0ec; color: var(--fire); }

/* Quiz nav buttons */
.quiz-nav { display: flex; justify-content: space-between; align-items: center; margin-top: 20px; gap: 10px; }
.btn-nav {
  background: var(--cream); border: 1.5px solid var(--ink-faint);
  color: var(--ink-light); font-family: 'Nunito', sans-serif;
  font-size: 11px; letter-spacing: 1px; text-transform: uppercase; font-weight: 700;
  padding: 10px 20px; border-radius: 100px; cursor: pointer; transition: all 0.2s;
  display: inline-flex; align-items: center; gap: 6px;
}
.btn-nav:hover:not(:disabled) { border-color: var(--ink); color: var(--ink); background: white; }
.btn-nav:disabled { opacity: 0.3; cursor: not-allowed; }
.btn-nav-next {
  background: var(--ink); color: var(--cream);
  border-color: var(--ink);
}
.btn-nav-next:hover:not(:disabled) { background: var(--ink-light); border-color: var(--ink-light); color: var(--cream); }

/* Modal overlay */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(26,39,68,0.5);
  display: flex; align-items: center; justify-content: center;
  z-index: 100; padding: 20px; animation: fadeIn 0.2s ease both;
}
.modal {
  background: var(--cream); border: 2px solid var(--ink);
  border-radius: 20px; padding: 32px 28px; max-width: 340px; width: 100%;
  box-shadow: 6px 6px 0 var(--ink-faint); animation: fadeUp 0.2s ease both;
  text-align: center;
}
.modal h3 { font-family: 'Playfair Display', serif; font-size: 20px; color: var(--ink); margin-bottom: 10px; }
.modal p { font-size: 14px; line-height: 1.6; color: var(--ink-light); margin-bottom: 24px; }
.modal-btns { display: flex; gap: 10px; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* ── QUESTION ── */
.qcard {
  background: white; border: 2px solid var(--ink); border-radius: 20px;
  padding: 36px 32px; position: relative;
  animation: fadeUp 0.4s ease both;
  box-shadow: 4px 4px 0px var(--ink-faint);
}
.qcard-corner { position: absolute; width: 8px; height: 8px; border-radius: 50%; background: var(--sun); }
.qcard-corner.tl { top:12px; left:12px; }
.qcard-corner.tr { top:12px; right:12px; background:var(--fire); }
.qcard-corner.bl { bottom:12px; left:12px; background:var(--blush-mid); }
.qcard-corner.br { bottom:12px; right:12px; background:var(--ink-faint); }
.q-label { font-size: 9px; letter-spacing: 3px; text-transform: uppercase; font-weight: 700; color: var(--ink-light); display: flex; align-items: center; gap: 6px; margin-bottom: 16px; }
.q-text { font-family: 'Playfair Display', serif; font-size: 20px; line-height: 1.5; color: var(--ink); margin-bottom: 28px; }
.options { display: flex; flex-direction: column; gap: 10px; }
.option {
  background: var(--cream); border: 1.5px solid var(--ink-faint); border-radius: 12px;
  padding: 14px 18px; color: var(--ink-light);
  font-family: 'Nunito', sans-serif; font-size: 15px; line-height: 1.5; font-weight: 600;
  cursor: pointer; text-align: left; transition: all 0.2s ease;
  display: flex; align-items: flex-start; gap: 10px;
}
.option-dot { width: 8px; height: 8px; border-radius: 50%; border: 2px solid var(--ink-faint); flex-shrink: 0; margin-top: 5px; transition: all 0.2s; }
.option:hover { border-color: var(--ink); color: var(--ink); background: var(--cream-dark); transform: translateX(4px); box-shadow: 3px 3px 0 var(--ink-faint); }
.option:hover .option-dot { border-color: var(--fire); background: var(--fire); }
.option.selected { border-color: var(--fire); background: white; color: var(--ink); box-shadow: 3px 3px 0 var(--fire-light); }
.option.selected .option-dot { background: var(--fire); border-color: var(--fire); }
.option.faded { opacity: 0.25; pointer-events: none; }

/* ── RESULTS ── */
.result { animation: fadeUp 0.6s ease both; }
.result-hero {
  text-align: center; background: white;
  border: 2px solid var(--ink); border-radius: 24px;
  padding: 40px 32px 32px; margin-bottom: 16px;
  position: relative; box-shadow: 4px 4px 0 var(--ink-faint); overflow: hidden;
}
.result-hero::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 6px;
  background: linear-gradient(90deg, var(--sun), var(--fire), var(--blush-mid));
}
.hero-node { position: absolute; border-radius: 50%; }
.arch-symbol-big { font-size: 64px; display: block; margin-bottom: 12px; filter: drop-shadow(2px 3px 0 var(--sun-light)); animation: pulse 3s ease-in-out infinite; }
.arch-name { font-family: 'Playfair Display', serif; font-size: clamp(28px,6vw,42px); font-weight: 700; color: var(--ink); letter-spacing: -0.5px; margin-bottom: 4px; }
.arch-latin { font-style: italic; font-size: 13px; color: #8090b8; letter-spacing: 1.5px; margin-bottom: 20px; }
.arch-traits { display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; }
.trait-pill { background: var(--cream); border: 1.5px solid var(--ink-faint); border-radius: 20px; padding: 4px 14px; font-size: 11px; letter-spacing: 1px; text-transform: uppercase; font-weight: 700; color: var(--ink-light); }

.rsection { background: white; border: 1.5px solid var(--ink-faint); border-radius: 16px; padding: 28px; margin-bottom: 12px; position: relative; overflow: hidden; }
.rsection-accent { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; }
.rsection-accent.sun { background: var(--sun); }
.rsection-accent.fire { background: var(--fire); }
.rsection-accent.blush { background: var(--blush-mid); }
.rsection-accent.ink { background: var(--ink-light); }
.rsection-accent.node { background: linear-gradient(180deg, var(--sun), var(--fire)); }
.rsection-label { font-size: 9px; letter-spacing: 3px; text-transform: uppercase; font-weight: 700; color: var(--ink-light); display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
.rsection-text { font-size: 15px; line-height: 1.8; color: #3a4870; }

.behavior-list { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-top: 14px; }
.behavior-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 15px; line-height: 1.6; color: #3a4870; }
.behavior-list li .bnode { width: 8px; height: 8px; border-radius: 50%; background: var(--fire); flex-shrink: 0; margin-top: 6px; border: 2px solid var(--cream); box-shadow: 0 0 0 1.5px var(--fire); }
.behavior-list li.shadow-li .bnode { background: var(--blush-mid); box-shadow: 0 0 0 1.5px var(--blush-mid); }
.shadow-inner { margin-top: 18px; padding-top: 18px; border-top: 1.5px dashed var(--ink-faint); }
.shadow-label { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; font-weight: 700; color: #8090b8; margin-bottom: 10px; display: flex; align-items: center; gap: 6px; }

.arch-recs { display: flex; flex-direction: column; gap: 10px; margin-top: 14px; }
.arch-rec { background: var(--cream); border: 1.5px solid var(--ink-faint); border-radius: 12px; padding: 16px 18px; display: flex; gap: 14px; align-items: flex-start; }
.rec-symbol-wrap { width: 36px; height: 36px; flex-shrink: 0; background: white; border: 1.5px solid var(--ink-faint); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; }
.rec-name { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; font-weight: 700; color: var(--fire); margin-bottom: 6px; }
.rec-text { font-size: 14px; line-height: 1.65; color: #4a5580; }

.score-list { display: flex; flex-direction: column; gap: 12px; margin-top: 14px; }
.score-row { display: flex; align-items: center; gap: 10px; }
.score-sym { font-size: 16px; flex-shrink: 0; }
.score-name { font-size: 11px; letter-spacing: 1px; text-transform: uppercase; font-weight: 700; color: var(--ink-light); min-width: 96px; }
.score-track { flex: 1; height: 6px; background: var(--cream-dark); border-radius: 4px; overflow: hidden; }
.score-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, var(--sun), var(--fire)); transition: width 1.2s cubic-bezier(0.34,1.2,0.64,1); }
.score-pct { font-size: 10px; font-weight: 700; color: #8090b8; min-width: 30px; text-align: right; }
.score-row.top .score-name { color: var(--ink); }
.score-row.top .score-fill { background: linear-gradient(90deg, var(--fire), var(--fire-light)); }

/* ── BIBLIOTECA ── */
.biblioteca { animation: fadeUp 0.5s ease both; }
.biblioteca-header { text-align: center; margin-bottom: 32px; }
.biblioteca-header h2 { font-family: 'Playfair Display', serif; font-size: clamp(26px,5vw,36px); font-weight: 700; color: var(--ink); margin-bottom: 8px; line-height: 1.2; }
.biblioteca-header p { font-size: 15px; line-height: 1.7; color: var(--ink-light); font-style: italic; max-width: 420px; margin: 0 auto; }

/* Constellation grid */
.arch-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 12px; margin-bottom: 16px;
}
.arch-card {
  background: white; border: 1.5px solid var(--ink-faint);
  border-radius: 16px; padding: 20px 18px;
  cursor: pointer; transition: all 0.22s ease;
  position: relative; overflow: hidden;
  display: flex; flex-direction: column; gap: 10px;
}
.arch-card::before {
  content: ''; position: absolute;
  top: 0; left: 0; right: 0; height: 3px;
  background: var(--sun); transition: height 0.2s;
}
.arch-card:hover { transform: translateY(-3px); box-shadow: 4px 6px 0 var(--ink-faint); border-color: var(--ink); }
.arch-card:hover::before { height: 5px; }

/* Individual accent colors per archetype card */
.arch-card[data-key="heroe"]::before   { background: #e8441a; }
.arch-card[data-key="mago"]::before    { background: #6b4db8; }
.arch-card[data-key="sabio"]::before   { background: #2d7aab; }
.arch-card[data-key="explorador"]::before { background: #2a9d6f; }
.arch-card[data-key="amante"]::before  { background: #d4507a; }
.arch-card[data-key="cuidador"]::before { background: #e8941a; }
.arch-card[data-key="creador"]::before { background: #8a6b2a; }
.arch-card[data-key="rebelde"]::before { background: #c43020; }

.arch-card-top { display: flex; align-items: center; gap: 10px; }
.arch-card-symbol { font-size: 28px; filter: drop-shadow(1px 2px 0 rgba(0,0,0,0.08)); }
.arch-card-title { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 700; color: var(--ink); line-height: 1.2; }
.arch-card-latin { font-style: italic; font-size: 11px; color: #8090b8; letter-spacing: 1px; }
.arch-card-traits { display: flex; flex-wrap: wrap; gap: 4px; }
.arch-card-trait { background: var(--cream); border: 1px solid var(--ink-faint); border-radius: 10px; padding: 2px 8px; font-size: 10px; letter-spacing: 0.5px; font-weight: 700; text-transform: uppercase; color: #6070a0; }
.arch-card-preview { font-size: 13px; line-height: 1.6; color: #6070a0; }
.arch-card-arrow { position: absolute; bottom: 14px; right: 16px; font-size: 16px; color: var(--ink-faint); transition: all 0.2s; }
.arch-card:hover .arch-card-arrow { color: var(--fire); transform: translateX(3px); }

/* Constellation SVG map */
.constellation-map {
  background: white; border: 1.5px solid var(--ink-faint);
  border-radius: 16px; padding: 20px; margin-bottom: 16px;
  text-align: center;
}
.constellation-map-label { font-size: 9px; letter-spacing: 3px; text-transform: uppercase; font-weight: 700; color: var(--ink-light); margin-bottom: 14px; display: flex; align-items: center; justify-content: center; gap: 6px; }

/* ── ARCHETYPE DETAIL VIEW ── */
.arch-detail { animation: fadeUp 0.45s ease both; }
.detail-header {
  background: white; border: 2px solid var(--ink); border-radius: 24px;
  padding: 36px 32px 28px; margin-bottom: 14px;
  position: relative; overflow: hidden;
  box-shadow: 4px 4px 0 var(--ink-faint);
  text-align: center;
}
.detail-header::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 5px;
}
.detail-back { margin-bottom: 20px; }

/* ── ANIMATIONS ── */
@keyframes fadeUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
@keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.06); } }
@keyframes spinSlow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>
</head>
<body>
<div class="container" id="app"></div>
<script>

const MAX_THEORETICAL = 30;

// Accent colors per archetype
const ACCENT = {
  heroe:'#e8441a', mago:'#6b4db8', sabio:'#2d7aab',
  explorador:'#2a9d6f', amante:'#d4507a', cuidador:'#e8941a',
  creador:'#8a6b2a', rebelde:'#c43020'
};

const ARCHETYPES = {
  heroe: {
    name:"El Héroe", latin:"Victor et Defensor", symbol:"⚔️",
    core:"Eres quien afronta los desafíos de frente. Tu energía fundamental es la de superar obstáculos y demostrar —primero a ti mismo— que eres capaz. Transformas el miedo en acción, el obstáculo en propósito. Necesitas sentir que tu vida tiene una misión y que estás a la altura de ella.",
